# Copy this file to .env and fill in your values
# DO NOT commit .env — it contains secrets

PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Strong random string for JWT signing
JWT_SECRET=change-this-to-a-strong-random-string

# Neon PostgreSQL (or any PostgreSQL URL)
# Get a free DB at https://neon.tech
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require&connect_timeout=20"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require&connect_timeout=20"

# LLM Provider Mode: api | ml | mock
# - api: use Gemini (or any OpenAI-compatible API) — requires keys below
# - ml: use local FastAPI inference server (run ml/ separately)
# - mock: static mock responses (no API needed, for dev/testing)
LLM_PROVIDER_MODE=api

# Gemini via OpenAI-compatible endpoint
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
LLM_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.0-flash

# ML inference server (only needed when LLM_PROVIDER_MODE=ml)
ML_MODEL_URL=http://localhost:8001

# Seed admin credentials
DEFAULT_ADMIN_EMAIL=admin@feedbackai.dev
DEFAULT_ADMIN_PASSWORD=Admin123!
